FROM node:20-bookworm-slim AS base
WORKDIR /app/backend

ENV PORT=8080

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates openssl \
  && rm -rf /var/lib/apt/lists/*

# Install deps (includes dev deps for TypeScript build + prisma generate)
FROM base AS deps
COPY backend/package.json backend/package-lock.json ./
# NOTE: build needs devDependencies (typescript/prisma). Do not let NODE_ENV=production strip them.
RUN npm ci --include=dev

# Build backend
FROM deps AS build
COPY backend/tsconfig.json ./tsconfig.json
COPY backend/src ./src
RUN mkdir -p ./prisma
COPY prisma/schema.prisma ./prisma/schema.prisma

# Generate Prisma client for the backend package.
# Important: run against a schema path *inside* /app/backend so Prisma can find backend/package.json
# and will not attempt auto-install in /app (which may fail in locked-down build environments).
RUN npx prisma generate --schema ./prisma/schema.prisma --generator client
RUN npm run build
RUN npm prune --omit=dev

# Runtime
FROM base AS runtime
WORKDIR /app/backend
ENV NODE_ENV=production

COPY --from=build /app/backend/node_modules ./node_modules
COPY --from=build /app/backend/dist ./dist

EXPOSE 8080
CMD ["node", "dist/app.js"]
