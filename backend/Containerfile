FROM node:20-bookworm-slim AS base
WORKDIR /app/backend

ENV PORT=8080

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates openssl \
  && rm -rf /var/lib/apt/lists/*

# Install deps (includes dev deps for TypeScript build + prisma generate)
FROM base AS deps
COPY backend/package.json backend/package-lock.json ./
# NOTE: build needs devDependencies (typescript/prisma). Do not let NODE_ENV=production strip them.
RUN npm ci --include=dev

# Build backend
FROM deps AS build
COPY backend/tsconfig.json ./tsconfig.json
COPY backend/src ./src
COPY prisma /app/prisma

# Generate Prisma client (schema is in /app/prisma, referenced by backend/package.json prisma.schema)
RUN npx prisma generate --schema /app/prisma/schema.prisma
RUN npm run build
RUN npm prune --omit=dev

# Runtime
FROM base AS runtime
WORKDIR /app/backend
ENV NODE_ENV=production

COPY --from=build /app/backend/node_modules ./node_modules
COPY --from=build /app/backend/dist ./dist

EXPOSE 8080
CMD ["node", "dist/app.js"]
