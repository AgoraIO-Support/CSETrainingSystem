server {
    listen 443 ssl http2;
    server_name your-domain.example.com;

    ssl_certificate     /etc/letsencrypt/live/your-domain/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain/privkey.pem;

    client_max_body_size 10m;

    location /api/mcp {
        # Restrict to trusted internal callers only.
        allow 10.0.0.10;
        allow 10.0.0.11;
        deny all;

        proxy_pass http://127.0.0.1:3000/api/mcp;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Request-Id $request_id;

        # Pass service token and trusted user context through the gateway only.
        proxy_set_header Authorization $http_authorization;
        proxy_set_header x-sme-user-email $http_x_sme_user_email;
        proxy_set_header x-mcp-caller-id internal-gateway;

        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Request-Id $request_id;
    }
}
