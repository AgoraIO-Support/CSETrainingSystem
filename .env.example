NODE_ENV=dev
JWT_SECRET=xxx
DATABASE_URL=postgresql://xxx:xxx@cselearning-postgres:5432/cselearning-database?schema=public
AWS_REGION=xxx
AWS_S3_BUCKET_NAME=xxx
AWS_S3_ASSET_PREFIX=assets
CSE_ASSET_DELIVERY_MODE=s3_presigned
CSE_ASSET_URL_TTL_SECONDS=43200

OPENAI_API_KEY=xxx
OPENAI_MODEL=gpt-4o

NEXT_PUBLIC_APP_URL=http://localhost:3000

# CloudFront signed cookies (optional - only needed for private course materials)
CLOUDFRONT_SIGNED_COOKIE_TTL_HOURS=12
CLOUDFRONT_DOMAIN=xxx.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID="xxx"
CLOUDFRONT_PRIVATE_KEY="xxx"
# COOKIE_DOMAIN= (optional)
