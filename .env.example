NODE_ENV=dev
JWT_SECRET=xxx
DATABASE_URL=postgresql://xxx:xxx@cselearning-postgres:5432/cselearning-database?schema=public
AWS_REGION=xxx
AWS_S3_BUCKET_NAME=xxx
AWS_S3_ASSET_PREFIX=assets
CSE_ASSET_DELIVERY_MODE=s3_presigned
CSE_ASSET_URL_TTL_SECONDS=43200

OPENAI_API_KEY=xxx
OPENAI_MODEL=gpt-4o

NEXT_PUBLIC_APP_URL=http://localhost:3000
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# Optional: enable API category logs and include wecom request/response body in logs
CSE_LOG=api
CSE_WECOM_LOG_CONTENT=1
CSE_OPENAI_LOG_CONTENT=1
# Optional: model pricing (USD per 1M tokens) for per-request cost logs.
# This supports versioned names (e.g. "gpt-5.2-2025-12-11" uses "gpt-5.2" when provided).
CSE_OPENAI_CHAT_PRICING_JSON={"gpt-5.2":{"inputPer1M":1.75,"cachedInputPer1M":0.175,"outputPer1M":14},"gpt-5.1":{"inputPer1M":1.25,"cachedInputPer1M":0.125,"outputPer1M":10},"gpt-4o":{"inputPer1M":2.5,"cachedInputPer1M":1.25,"outputPer1M":10},"gpt-4o-mini":{"inputPer1M":0.15,"cachedInputPer1M":0.075,"outputPer1M":0.6}}

# CloudFront signed cookies (optional - only needed for private course materials)
CLOUDFRONT_SIGNED_COOKIE_TTL_HOURS=12
CLOUDFRONT_DOMAIN=xxx.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID="xxx"
CLOUDFRONT_PRIVATE_KEY="xxx"
# COOKIE_DOMAIN= (optional)

# Exam Invitation Notification
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
AI_ASSISTANT_HISTORY_MESSAGES=0
