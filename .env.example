# Environment variables for CSE Training System
#
# Notes:
# - Prefer NOT storing long-lived AWS keys in production (use an instance/task role).
# - If you use `podman --env-file`, avoid wrapping values in quotes.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:<PASSWORD>@<HOST>:5432/<DB>?schema=public

# -----------------------------------------------------------------------------
# Auth (required for local auth + backend admin delete)
# -----------------------------------------------------------------------------
# Used to sign/verify the app's HS256 Bearer tokens (login + API auth).
# Required unless you fully switch to Supabase auth and configure the backend verifier accordingly.
JWT_SECRET=<GENERATE_A_STRONG_RANDOM_SECRET>

# Optional: Supabase Auth (only if you use Supabase tokens)
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CSE Training System

# Optional: Fastify backend base URL (needed for course materials CF cookies and admin delete proxies)
# Server-only URL (Next.js server -> backend). In production, keep backend private and reachable only from the app.
BACKEND_INTERNAL_URL=http://127.0.0.1:8080

# -----------------------------------------------------------------------------
# AWS S3 asset storage + delivery
# -----------------------------------------------------------------------------
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=cse-training-bucket

# Optional: AWS credentials (use for local dev if you are not using AWS_PROFILE)
# AWS_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
# AWS_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>

# Optional: use a separate bucket for assets; if unset, falls back to AWS_S3_BUCKET_NAME
# AWS_S3_ASSET_BUCKET_NAME=cse-training-bucket

# Keep your existing prefix (you chose /CSETraining/*)
AWS_S3_ASSET_PREFIX=CSETraining

# If you use a public CloudFront domain for unsigned URLs
# AWS_CLOUDFRONT_DOMAIN=<your-cloudfront-domain-or-custom-domain>
# AWS_ASSET_PUBLIC_BASE_URL=https://<your-cloudfront-domain-or-custom-domain>

# Asset delivery mode:
# - s3_presigned: local dev default (no CloudFront signing required)
# - cloudfront_signed: production recommended (private assets)
# - public: unsigned URLs (not recommended for private assets)
CSE_ASSET_DELIVERY_MODE=s3_presigned
CSE_ASSET_URL_TTL_SECONDS=43200

# CloudFront signed URL config (required when CSE_ASSET_DELIVERY_MODE=cloudfront_signed)
CLOUDFRONT_KEY_PAIR_ID=<KEY_PAIR_ID>
CLOUDFRONT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Backend-only (Fastify): CloudFront signed cookies config (course materials page)
CLOUDFRONT_DOMAIN=<cloudfront-domain-or-custom-domain>
COOKIE_DOMAIN=<cookie-domain-or-empty>
CLOUDFRONT_SIGNED_COOKIE_TTL_HOURS=12

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_MODEL=gpt-4o-mini

# Optional tuning
# VTT_TO_XML_ENRICH_TIMEOUT_MS=20000
# EXAM_GENERATION_MAX_XML_CHARS=200000
# EXAM_GENERATION_MAX_XML_CHARS_PER_LESSON=120000

# -----------------------------------------------------------------------------
# Email (optional, via Resend)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=<RESEND_API_KEY>
# RESEND_FROM_EMAIL=noreply@cselearning.club

# -----------------------------------------------------------------------------
# Logging (optional)
# -----------------------------------------------------------------------------
# CSE_LOG=api,db,s3,openai
# CSE_LOG_MAX_CHARS=0
# CSE_DB_LOG=1
# CSE_DB_QUERY_LOG=1
# CSE_OPENAI_LOG_CONTENT=0
