NODE_ENV=dev
JWT_SECRET=xxx
DATABASE_URL=postgresql://xxx:xxx@cselearning-postgres:5432/cselearning-database?schema=public
AWS_REGION=xxx
AWS_S3_BUCKET_NAME=xxx
AWS_S3_ASSET_PREFIX=CSETraining_Dev
CSE_ASSET_DELIVERY_MODE=s3_presigned
CSE_ASSET_URL_TTL_SECONDS=43200



OPENAI_API_KEY=xxx
OPENAI_MODEL=gpt-4o

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

  # CloudFront signed-cookie（backend 强制要求）
CLOUDFRONT_SIGNED_COOKIE_TTL_HOURS=12
CLOUDFRONT_DOMAIN=xxx.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID="xxx"
CLOUDFRONT_PRIVATE_KEY="xxx"
## For Podman: Next.js server runs inside `cselearning-web` container, so `localhost` points to itself.
## Use the backend service name on the podman network.
BACKEND_INTERNAL_URL=http://cselearning-backend:8080
